<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>HELIOS Compliance Report</title>
  <style>
    @page { size: A4; margin: 1.5cm; }
    body { font-family: "Inter", "Segoe UI", "Helvetica Neue", Arial, sans-serif; color: #1f2937; font-size: 11px; }
    h1, h2, h3 { color: #1e3a5f; margin: 0 0 8px 0; }
    .header { border-bottom: 2px solid #cbd5e1; padding-bottom: 10px; margin-bottom: 12px; }
    .muted { color: #64748b; }
    .summary-box { border: 1px solid #cbd5e1; background: #f8fafc; padding: 10px; margin: 12px 0; }
    .grade { font-size: 24px; font-weight: 700; }
    .grade-A, .grade-B { color: #166534; }
    .grade-C { color: #854d0e; }
    .grade-D, .grade-F { color: #991b1b; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; margin-bottom: 12px; }
    th, td { border: 1px solid #d1d5db; padding: 6px; vertical-align: top; text-align: left; }
    th { background: #e2e8f0; color: #0f172a; }
    .badge { border-radius: 8px; padding: 2px 8px; font-size: 10px; font-weight: 700; color: #fff; display: inline-block; }
    .pass, .info { background: #16a34a; }
    .warn { background: #d97706; }
    .fail { background: #dc2626; }
    .skip { background: #64748b; }
    footer { margin-top: 14px; font-size: 9px; color: #64748b; border-top: 1px solid #d1d5db; padding-top: 8px; }
    .mono { font-family: Menlo, Consolas, monospace; }
  </style>
</head>
<body>
  <section class="header">
    <h1>HELIOS Compliance Report</h1>
    <div class="muted">Run ID: <span class="mono">{{ record.run_id }}</span></div>
    <div class="muted">Date: {{ now.isoformat() }}</div>
    <div class="muted">Pipeline: {{ record.pipeline_name }} {{ record.pipeline_version or "" }}</div>
  </section>

  <section class="summary-box">
    <h2>Executive Summary</h2>
    <div class="grade grade-{{ score.grade }}">Score {{ score.score }} / 100 ({{ score.grade }})</div>
    <div class="muted">Passed: {{ score.passed }} | Warned: {{ score.warned }} | Failed: {{ score.failed }}</div>
  </section>

  <h2>Standards Coverage</h2>
  <table>
    <thead><tr><th>Standard Family</th><th>Required</th><th>Checked</th><th>Status</th></tr></thead>
    <tbody>
      <tr><td>ISO 15189:2022</td><td>Yes</td><td>Yes</td><td>{{ "Met" if score.failed == 0 else "Partial" }}</td></tr>
      <tr><td>GA4GH standards</td><td>Yes</td><td>Yes</td><td>{{ "Met" if score.failed == 0 else "Partial" }}</td></tr>
      <tr><td>EU AI Act</td><td>Contextual</td><td>Yes</td><td>Documented</td></tr>
    </tbody>
  </table>

  <h2>Check Results</h2>
  <table>
    <thead><tr><th>Check ID</th><th>Name</th><th>Status</th><th>Evidence</th></tr></thead>
    <tbody>
    {% for check in checks %}
      <tr>
        <td class="mono">{{ check.check_id }}</td>
        <td>{{ check.message.split(":")[0] }}</td>
        <td><span class="badge {{ check.status }}">{{ check.status|upper }}</span></td>
        <td class="mono">{{ check.evidence }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>File Provenance</h2>
  <table>
    <thead><tr><th>Type</th><th>Path</th><th>SHA-256</th></tr></thead>
    <tbody>
    {% for f in record.input_files %}
      <tr><td>Input</td><td>{{ f.path }}</td><td class="mono">{{ f.sha256[:8] }}...{{ f.sha256[-8:] }}</td></tr>
    {% endfor %}
    {% for f in record.output_files %}
      <tr><td>Output</td><td>{{ f.path }}</td><td class="mono">{{ f.sha256[:8] }}...{{ f.sha256[-8:] }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Container Inventory</h2>
  <table>
    <thead><tr><th>Name</th><th>Tag</th><th>Pinned</th></tr></thead>
    <tbody>
    {% for c in record.containers %}
      <tr><td>{{ c.name }}</td><td>{{ c.tag }}</td><td>{{ c.pinned }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Signature</h2>
  <p>
    Signed by: {{ record.signature.algorithm if record.signature else "unsigned" }}<br/>
    Public key fingerprint: {{ record.signature.public_key_fingerprint if record.signature else "n/a" }}<br/>
    Timestamp: {{ record.signature.signed_at.isoformat() if record.signature else "n/a" }}
  </p>

  <footer>
    Generated by HELIOS {{ version }} — This document is an evidence artifact, not a legal certification.
  </footer>
</body>
</html>
